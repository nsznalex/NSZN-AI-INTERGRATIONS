!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NSZN AI — OpenClaw for Home Services</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #090909;
    --surface: #111111;
    --surface2: #1a1a1a;
    --border: #222222;
    --amber: #F59E0B;
    --amber-dim: #92600a;
    --white: #F5F0E8;
    --gray: #888888;
    --gray-light: #AAAAAA;
    --red: #E53E3E;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* NOISE OVERLAY */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    opacity: 0.025;
    pointer-events: none;
    z-index: 9999;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 48px;
    border-bottom: 1px solid var(--border);
    background: rgba(9,9,9,0.92);
    backdrop-filter: blur(12px);
  }

  .nav-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 0.12em;
    color: var(--white);
  }

  .nav-logo span { color: var(--amber); }

  nav ul {
    display: flex;
    gap: 36px;
    list-style: none;
  }

  nav ul a {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--gray);
    text-decoration: none;
    transition: color 0.2s;
  }

  nav ul a:hover { color: var(--white); }

  .nav-cta {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 10px 20px;
    border: 1px solid var(--amber);
    color: var(--amber);
    text-decoration: none;
    transition: all 0.2s;
  }

  .nav-cta:hover {
    background: var(--amber);
    color: var(--black);
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 48px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse 60% 50% at 70% 40%, rgba(245,158,11,0.06) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 20% 80%, rgba(245,158,11,0.03) 0%, transparent 60%);
  }

  .hero-tag {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .hero-tag::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--amber);
  }

  h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(72px, 10vw, 148px);
    line-height: 0.92;
    letter-spacing: 0.01em;
    margin-bottom: 40px;
    position: relative;
    z-index: 1;
  }

  h1 em {
    font-style: normal;
    color: var(--amber);
    display: block;
  }

  .hero-sub {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: end;
    position: relative;
    z-index: 1;
    max-width: 900px;
  }

  .hero-desc {
    font-size: 17px;
    line-height: 1.65;
    color: var(--gray-light);
    font-weight: 300;
  }

  .hero-desc strong { color: var(--white); font-weight: 500; }

  .hero-stats {
    display: flex;
    flex-direction: column;
    gap: 16px;
    border-left: 1px solid var(--border);
    padding-left: 48px;
  }

  .stat {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    color: var(--amber);
    line-height: 1;
  }

  .stat-label {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray);
  }

  .scroll-hint {
    position: absolute;
    bottom: 32px;
    right: 48px;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray);
    writing-mode: vertical-rl;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .scroll-hint::after {
    content: '';
    display: block;
    width: 1px;
    height: 48px;
    background: var(--border);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  /* SECTION SHARED */
  section {
    padding: 120px 48px;
    border-top: 1px solid var(--border);
  }

  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 48px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .section-label::after {
    content: '';
    flex: 1;
    max-width: 48px;
    height: 1px;
    background: var(--amber-dim);
  }

  h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(42px, 6vw, 80px);
    line-height: 0.95;
    letter-spacing: 0.02em;
    margin-bottom: 16px;
  }

  /* PROBLEM */
  .problem-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-top: 64px;
    border: 1px solid var(--border);
  }

  .problem-item {
    padding: 40px 48px;
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }

  .problem-item:nth-child(odd) { border-right: 1px solid var(--border); }
  .problem-item:nth-last-child(-n+2) { border-bottom: none; }

  .problem-item:hover { background: var(--surface); }

  .problem-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 80px;
    color: var(--border);
    line-height: 1;
    position: absolute;
    top: 16px;
    right: 24px;
    transition: color 0.3s;
  }

  .problem-item:hover .problem-num { color: var(--surface2); }

  .problem-icon {
    font-size: 28px;
    margin-bottom: 20px;
  }

  .problem-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 10px;
    color: var(--white);
  }

  .problem-desc {
    font-size: 14px;
    color: var(--gray);
    line-height: 1.7;
    max-width: 340px;
  }

  /* WORKFLOWS */
  .workflows { background: var(--surface); }

  .workflow-intro {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    margin-bottom: 72px;
    align-items: end;
  }

  .workflow-intro p {
    color: var(--gray-light);
    font-size: 16px;
    line-height: 1.7;
    font-weight: 300;
  }

  .workflow-badge {
    display: inline-block;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 5px 12px;
    border: 1px solid var(--amber);
    color: var(--amber);
    margin-bottom: 12px;
  }

  .workflows-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
  }

  .workflow-row {
    display: grid;
    grid-template-columns: 80px 1fr 200px 160px;
    align-items: center;
    padding: 28px 32px;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.2s;
    gap: 24px;
  }

  .workflow-row:last-child { border-bottom: none; }
  .workflow-row:hover { background: var(--surface2); }

  .workflow-row.active { background: rgba(245,158,11,0.05); }

  .wf-num {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--amber);
    letter-spacing: 0.1em;
  }

  .wf-name {
    font-size: 16px;
    font-weight: 500;
    color: var(--white);
  }

  .wf-name small {
    display: block;
    font-size: 12px;
    color: var(--gray);
    font-weight: 400;
    margin-top: 3px;
  }

  .wf-time {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--amber);
    text-align: right;
  }

  .wf-niches {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .niche-tag {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 8px;
    background: var(--border);
    color: var(--gray-light);
  }

  .workflow-detail {
    display: none;
    padding: 0 32px 28px 136px;
    background: rgba(245,158,11,0.03);
    border-bottom: 1px solid var(--border);
  }

  .workflow-detail.open { display: block; }

  .workflow-detail p {
    font-size: 14px;
    color: var(--gray-light);
    line-height: 1.75;
    max-width: 680px;
    margin-bottom: 16px;
  }

  .wf-meta {
    display: flex;
    gap: 32px;
    margin-top: 8px;
  }

  .wf-meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .wf-meta-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gray);
  }

  .wf-meta-val {
    font-size: 13px;
    color: var(--white);
  }

  /* PRICING */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin-top: 64px;
    border: 1px solid var(--border);
  }

  .price-card {
    padding: 40px 32px;
    border-right: 1px solid var(--border);
    position: relative;
    transition: background 0.3s;
  }

  .price-card:last-child { border-right: none; }
  .price-card:hover { background: var(--surface2); }

  .price-card.featured {
    background: var(--surface);
    border-top: 3px solid var(--amber);
    margin-top: -3px;
  }

  .price-card.featured:hover { background: #1d1d1d; }

  .price-tier {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gray);
    margin-bottom: 20px;
  }

  .price-card.featured .price-tier { color: var(--amber); }

  .price-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 0.04em;
    margin-bottom: 4px;
  }

  .price-amount {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 52px;
    line-height: 1;
    color: var(--amber);
    margin-bottom: 4px;
  }

  .price-sub {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--gray);
    margin-bottom: 32px;
  }

  .price-divider {
    height: 1px;
    background: var(--border);
    margin-bottom: 28px;
  }

  .price-includes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 32px;
  }

  .price-includes li {
    font-size: 13px;
    color: var(--gray-light);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    line-height: 1.5;
  }

  .price-includes li::before {
    content: '→';
    color: var(--amber);
    font-size: 11px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .price-excludes {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--gray);
    letter-spacing: 0.06em;
    margin-bottom: 28px;
    line-height: 1.6;
  }

  .price-cta {
    display: block;
    width: 100%;
    padding: 13px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--white);
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
    text-decoration: none;
  }

  .price-cta:hover {
    border-color: var(--amber);
    color: var(--amber);
  }

  .price-card.featured .price-cta {
    background: var(--amber);
    border-color: var(--amber);
    color: var(--black);
    font-weight: 500;
  }

  .price-card.featured .price-cta:hover {
    background: transparent;
    color: var(--amber);
  }

  /* HOSTING */
  .hosting-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 64px;
  }

  .host-card {
    border: 1px solid var(--border);
    padding: 36px 32px;
    transition: border-color 0.3s;
  }

  .host-card:hover { border-color: var(--amber-dim); }

  .host-icon { font-size: 32px; margin-bottom: 20px; }

  .host-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 26px;
    letter-spacing: 0.04em;
    margin-bottom: 8px;
  }

  .host-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--amber);
    margin-bottom: 16px;
  }

  .host-desc {
    font-size: 14px;
    color: var(--gray);
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .host-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    color: var(--white);
    line-height: 1;
    margin-bottom: 4px;
  }

  .host-price-note {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--gray);
    letter-spacing: 0.08em;
  }

  /* ZONES */
  .zones-section { background: var(--surface); }

  .zones-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
    margin-top: 64px;
    border: 1px solid var(--border);
  }

  .zone-card {
    padding: 48px 40px;
    border-right: 1px solid var(--border);
    position: relative;
  }

  .zone-card:last-child { border-right: none; }

  .zone-letter {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 120px;
    line-height: 1;
    color: var(--border);
    position: absolute;
    top: 16px;
    right: 24px;
  }

  .zone-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--amber);
    margin-bottom: 16px;
  }

  .zone-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    margin-bottom: 8px;
  }

  .zone-fee {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    color: var(--amber);
    margin-bottom: 16px;
  }

  .zone-cities {
    font-size: 13px;
    color: var(--gray);
    line-height: 1.8;
  }

  /* CTA SECTION */
  .cta-section {
    padding: 160px 48px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--border);
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 70% at 50% 50%, rgba(245,158,11,0.05) 0%, transparent 70%);
  }

  .cta-section h2 {
    font-size: clamp(56px, 8vw, 110px);
    position: relative;
    z-index: 1;
    margin-bottom: 24px;
  }

  .cta-section p {
    font-size: 18px;
    color: var(--gray-light);
    max-width: 520px;
    margin: 0 auto 48px;
    position: relative;
    z-index: 1;
    font-weight: 300;
  }

  .cta-btns {
    display: flex;
    gap: 16px;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .btn-primary {
    padding: 18px 48px;
    background: var(--amber);
    color: var(--black);
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s;
  }

  .btn-primary:hover { background: #d97706; }

  .btn-secondary {
    padding: 18px 48px;
    border: 1px solid var(--border);
    color: var(--gray-light);
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--white);
    color: var(--white);
  }

  /* FOOTER */
  footer {
    padding: 40px 48px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 0.12em;
  }

  .footer-logo span { color: var(--amber); }

  footer p {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--gray);
    letter-spacing: 0.1em;
  }

  /* FADE IN */
  .fade-in {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* MOBILE */
  @media (max-width: 900px) {
    nav { padding: 16px 24px; }
    nav ul { display: none; }
    .hero { padding: 0 24px 64px; }
    section { padding: 80px 24px; }
    h1 { font-size: clamp(56px, 14vw, 100px); }
    .hero-sub, .workflow-intro { grid-template-columns: 1fr; gap: 32px; }
    .hero-stats { border-left: none; padding-left: 0; border-top: 1px solid var(--border); padding-top: 24px; flex-direction: row; flex-wrap: wrap; gap: 24px; }
    .problem-grid { grid-template-columns: 1fr; }
    .problem-item:nth-child(odd) { border-right: none; }
    .problem-item:nth-last-child(-n+2) { border-bottom: 1px solid var(--border); }
    .problem-item:last-child { border-bottom: none; }
    .workflow-row { grid-template-columns: 60px 1fr; }
    .wf-time, .wf-niches { display: none; }
    .pricing-grid { grid-template-columns: 1fr; }
    .price-card { border-right: none; border-bottom: 1px solid var(--border); }
    .price-card:last-child { border-bottom: none; }
    .hosting-grid { grid-template-columns: 1fr; }
    .zones-grid { grid-template-columns: 1fr; }
    .zone-card { border-right: none; border-bottom: 1px solid var(--border); }
    .zone-card:last-child { border-bottom: none; }
    .cta-section { padding: 100px 24px; }
    .cta-btns { flex-direction: column; align-items: center; }
    footer { flex-direction: column; gap: 16px; text-align: center; padding: 32px 24px; }
    .scroll-hint { display: none; }
    .workflow-detail { padding: 0 24px 24px 80px; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">NSZN<span>.</span>AI</div>
  <ul>
    <li><a href="#problem">The Problem</a></li>
    <li><a href="#workflows">Workflows</a></li>
    <li><a href="#pricing">Pricing</a></li>
    <li><a href="#hosting">Hosting</a></li>
    <li><a href="#zones">Zones</a></li>
  </ul>
  <a href="#contact" class="nav-cta">Book a Call</a>
</nav>

<!-- HERO -->
<section class="hero" style="border-top: none; padding-top: 0;">
  <div class="hero-bg"></div>

  <div class="hero-tag">NSZN AI — OpenClaw Implementation · CT / MA / RI</div>

  <h1>
    Stop Losing<br>Jobs To<br><em>Missed Calls.</em>
  </h1>

  <div class="hero-sub">
    <p class="hero-desc">
      We set up <strong>OpenClaw</strong> — an autonomous AI system — on-site at your office. Your team stops chasing follow-ups. Quotes go out faster. Jobs get booked. <strong>We handle the whole thing.</strong>
    </p>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-num">5–10</span>
        <span class="stat-label">Hours saved per week</span>
      </div>
      <div class="stat">
        <span class="stat-num">$2,995</span>
        <span class="stat-label">Starting price, all-in</span>
      </div>
      <div class="stat">
        <span class="stat-num">1 WK</span>
        <span class="stat-label">From call to live system</span>
